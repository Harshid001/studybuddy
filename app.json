{
  "expo": {
    "name": "StudyBuddy",
    "slug": "studybuddy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1a4480"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.studybuddy.admin"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a4480"
      },
      "package": "com.studybuddy.admin"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font"
    ],
    "scheme": "studybuddy"
  }
}
